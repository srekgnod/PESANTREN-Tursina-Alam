# ============================================
# Pesantren Tursina Alam — Environment Config
# Copy to .env and customize for your environment
# ============================================

# ── Application ──
APP_NAME=pesantren-api
APP_ENV=production
APP_PORT=8080
APP_URL=https://tursinaalam.sch.id

# ── Nginx ──
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
DOMAIN=tursinaalam.sch.id

# ── Frontend Build ──
VITE_API_URL=/api/v1
VITE_APP_NAME=Pesantren Tursina Alam

# ── PostgreSQL ──
DB_HOST=postgres
DB_PORT=5432
DB_USER=pesantren
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_32_CHARS
DB_NAME=pesantren_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_REDIS_PASSWORD
REDIS_DB=0

# ── JWT ──
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_STRING_USE_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ── Upload ──
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10

# ── CORS ──
CORS_ORIGINS=https://tursinaalam.sch.id

# ── WhatsApp (Fonnte API) ──
WA_API_URL=https://api.fonnte.com/send
WA_API_TOKEN=YOUR_FONNTE_API_TOKEN

# ── Logging ──
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log

# ── Backup ──
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backups
DB_CONTAINER=pesantren-postgres

# ── SSL ──
SSL_EMAIL=admin@tursinaalam.sch.id
